# CareerJudge Caddyfile — dev environment (hybrid mode: Vercel frontend + GCP backend)
# Domain: careerjudge.pp.ua (pointed to GCP 35.207.59.232)
#
# Caddy auto-provisions Let's Encrypt TLS certs.
# Routes:
#   /api/*      → backend (gunicorn on :8000) — PRESERVES /api prefix
#   /admin/*    → backend (Django admin for superuser emergency access)
#   /*          → proxy to Vercel frontend (browser stays on careerjudge.pp.ua)
#
# Run: docker compose -f infra/docker/docker-compose.dev.yml up -d backend caddy

careerjudge.pp.ua {
	encode gzip zstd

	# Backend API — use `handle` (not `handle_path`) to preserve the /api prefix
	# Django's urls.py expects /api/auth/login, /api/me/, /api/accounts/, etc.
	handle /api/* {
		reverse_proxy backend:8000 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# Django admin (superuser-only, kept for emergencies)
	handle /admin/* {
		reverse_proxy backend:8000
	}

	# Frontend — proxy to Vercel (browser stays on careerjudge.pp.ua)
	handle {
		reverse_proxy https://careerjudge-python.vercel.app {
			header_up Host careerjudge-python.vercel.app
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy same-origin
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	log {
		output file /data/caddy/access.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}
