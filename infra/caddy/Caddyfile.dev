# CareerJudge Caddyfile — dev environment (hybrid mode: Vercel frontend + GCP backend)
# Domain: careerjudge.pp.ua (pointed to GCP 35.207.59.232)
#
# Caddy auto-provisions Let's Encrypt TLS certs.
# Routes:
#   /api/*                → backend (gunicorn on :8000) — PRESERVES /api prefix
#   /admin/ (exact)       → backend (Django admin for superuser emergency access)
#   /admin/login/         → backend (Django admin login)
#   /admin/static/*       → backend (Django admin CSS/JS)
#   /*                    → proxy to Vercel frontend (browser stays on careerjudge.pp.ua)
#
# IMPORTANT: /admin/users, /admin/roles, /admin/permissions are REACT ROUTES
# (served by Vercel), NOT Django admin. Only /admin/ (exactly) and its
# sub-paths that Django admin actually uses should go to the backend.
#
# Run: docker compose -f infra/docker/docker-compose.dev.yml up -d backend caddy

careerjudge.pp.ua {
        encode gzip zstd

        # Allow large request bodies for video/audio file uploads (base64 in JSON)
        request_body {
                max_size 120MB
        }

        # Backend API — use `handle` (not `handle_path`) to preserve the /api prefix
        # Django's urls.py expects /api/auth/login, /api/me/, /api/accounts/, etc.
        handle /api/* {
                reverse_proxy backend:8000 {
                        header_up X-Forwarded-Proto {scheme}
                        header_up X-Forwarded-Host {host}
                        # Increase timeouts for large payloads (base64 video/audio in JSON)
                        # and slow DB operations (bulk options save with transaction).
                        transport http {
                                read_timeout 300s
                                write_timeout 300s
                                dial_timeout 10s
                        }
                }
        }

        # Django admin — ONLY the exact paths Django admin uses.
        # /admin/users, /admin/roles, /admin/permissions are React routes (go to Vercel).
        # Django admin paths: /admin/, /admin/login/, /admin/logout/,
        # /admin/auth/, /admin/accounts/, /admin/static/admin/*, etc.
        # We match these specific patterns to avoid catching React's /admin/* routes.
        @djangoAdmin {
                path /admin /admin/ /admin/login /admin/login/ /admin/logout /admin/logout/
                path /admin/auth/* /admin/accounts/* /admin/token_blacklist/*
                path /admin/static/admin/*
                path /admin/jsi18n/*
        }
        handle @djangoAdmin {
                reverse_proxy backend:8000
        }

        # Frontend — proxy to Vercel (browser stays on careerjudge.pp.ua)
        # This catches everything else including /admin/users, /admin/roles, etc.
        handle {
                reverse_proxy https://careerjudge-python.vercel.app {
                        header_up Host careerjudge-python.vercel.app
                        header_up X-Real-IP {remote_host}
                        header_up X-Forwarded-For {remote_host}
                }
        }

        # Security headers
        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
                X-Content-Type-Options nosniff
                X-Frame-Options DENY
                Referrer-Policy same-origin
                Permissions-Policy "geolocation=(), microphone=(), camera=()"
        }

        log {
                output file /data/caddy/access.log {
                        roll_size 10mb
                        roll_keep 5
                }
                format json
        }
}
