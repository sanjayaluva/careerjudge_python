  "introduction": {
    "description": "Profiling solutions require data transformation and integration. Two or more assessments and their data are transformed and integrated in different ways to generate integrated information for reporting.",
    "actor": "Psychometrician",
    "stages": [
      "Solution Definition",
      "Assessment Selection (minimum 2 assessments)",
      "Data Transformation (Banding, Mapping, Ranking with weights)",
      "Data Integration (summarized into a single value)"
    ],
    "note": "If user selects a Polar Assessment, some steps in data transformation are treated differently."
  },
  "processes": {
    "solution_definition": {
      "section": "2",
      "description": "Defines the title, purpose and description of the solution.",
      "steps": [
        "User clicks 'Create a New Solution' button",
        "System presents screen with entry fields: Solution Title, Purpose, Description, Image Upload",
        "User enters relevant text/uploads image and submits",
        "System creates a new Profiling Solution"
      ]
    },
    "assessment_selection": {
      "section": "3",
      "rules": [
        "At least 2 assessments must be selected",
        "Maximum 3 assessments"
      ],
      "precondition": "Assessments selected must have already been configured at Assessment Design phase",
      "steps": [
        "User clicks 'Select Assessments' button",
        "System shows list of assessments available in the system",
        "User selects assessments (at least 2, max 3)",
        "System shows entry field to enter name for each selected assessment",
        "User enters names for each selected assessment (e.g., CAT, CIA)"
      ]
    },
    "data_transformation": {
      "section": "4",
      "description": "Configuration for data transformation should be performed for all selected assessments.",
      "data_type_used": "Percentage data only",
      "note": "Percentile, STEN, STENINE data types are NOT eligible for solutioning purpose.",
      "standard_assessment": {
        "section": "4.1",
        "band_definition": {
          "section": "4.1.1",
          "description": "Summary scores (percentage scores) of assessment variables are called in for band definition.",
