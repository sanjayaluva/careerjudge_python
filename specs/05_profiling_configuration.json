            "At least two variables should be selected",
            "Max selected should not exceed the total number",
            "Min bands per variable: 2, Max: 10",
            "Band range should be between 0 and 100",
            "Two band values should not overlap"
          ],
          "steps": [
            "User clicks 'Define Band' button",
            "System asks to select one from list of selected assessments",
            "System lists all variables in that assessment",
            "User selects required number of variables",
            "System shows selected variables and entry fields for number of bands per variable",
            "User assigns numeric value (number of bands) for each variable",
            "System shows band rows with fields for band range and band code per band",
            "User defines band range and band code for each band for each variable"
