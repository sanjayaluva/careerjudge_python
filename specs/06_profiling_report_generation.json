{
  "meta": {
    "file": "06_profiling_report_generation.json",
    "source_pdf": "6__Profiling_Report_Generation_Process.pdf",
    "title": "Profiling Report Generation",
    "version": "1.0"
  },
  "introduction": {
    "description": "Profiling report process collects data inputs from Profiling Configuration Process to generate the profiling report.",
    "distinction_from_general_report": "Profiling report uses multiple assessments and transformed data inputs; general report uses a single assessment.",
    "stages": [
      "General Description and Data Selection Criteria",
      "Report Configuration (Raw Summary, FMI, PMI, VMI reports \u2014 all optional)",
      "Report Layout"
    ],
    "note": "Stages 2-5 are optional. User selects which reports to include in a particular profiling solution."
  },
  "processes": {
    "general_description_and_data_selection": {
      "section": "2",
      "define_report_title_and_description": {
        "section": "2.1",
        "steps": [
          "User clicks 'Profile Report' button",
          "System shows entry fields for report title and description",
          "User enters relevant inputs and submits"
        ],
        "sample_output": {
          "Report_Title": "Career Profiling Solution",
          "Report_Description": "This report addresses these questions and helps you know what your real strengths and difficulties are and which careers of choice would match your intellectual and personality profile. In the subsequent counselling session, we will have a thorough analysis of all 'what's and 'whys' and how to overcome the limitations."
        }
      },
      "defining_data_selection_criteria": {
        "section": "2.2",
        "description": "Only two types of data are pulled in for reporting due to large criterion lists.",
        "data_types": [
          {
            "type": "HFMI data",
            "label": "Data of criterions with highest FMIs"
          },
          {
            "type": "LFMI data",
            "label": "Data of criterions with lowest FMIs"
          }
        ],
        "extraction_modes": [
          "User-Initiated Selection",
          "System-Initiated Selection"
        ],
        "rules": [
          "One or both data types can be selected",
          "Only one extraction mode can be selected"
        ],
        "steps": [
          "User clicks 'Data Selection' button",
          "System asks user to select type of data: HFMI and/or LFMI",
          "User selects data type(s)",
          "System asks user to select extraction mode: User-initiated or System-initiated"
        ],
        "user_initiated_HFMI": {
          "steps": [
            "System asks to specify range of HFMI data to be sorted and displayed",
            "User specifies HFMI range (e.g., 85-100)",
            "System displays entry fields for specifying number of Categories and Criterions to extract",
            "User enters relevant numbers and submits",
            "System sorts FMI data with criterions and categories in ASCENDING order and displays all categories/criterions with FMI values within specified range",
            "User manually selects categories and criterions"
          ]
        },
        "user_initiated_LFMI": {
          "steps": [
            "System asks to specify range of LFMI data",
            "User specifies range (e.g., 85-100)",
            "System displays entry fields for number of Categories and Criterions",
            "User enters numbers and submits",
            "System sorts FMI data in DESCENDING order and displays categories/criterions within specified range",
            "User manually selects categories and criterions"
          ]
        },
        "system_initiated_HFMI": {
          "steps": [
            "System displays entry fields for number of Categories and Criterions to extract",
            "User enters numbers and submits",
            "System executes: Sorts FMI data in DESCENDING order \u2192 Identifies category with highest FMI \u2192 Selects criterions (as many as specified) with highest FMIs within that category \u2192 Repeats for next highest FMI category \u2192 Continues until specified number reached"
          ]
        },
        "system_initiated_LFMI": {
          "steps": [
            "System displays entry fields for number of Categories and Criterions",
            "User enters numbers and submits",
            "System executes: Sorts FMI data in ASCENDING order \u2192 Identifies category with lowest FMI \u2192 Selects criterions with lowest FMIs within that category \u2192 Repeats for next lowest FMI category \u2192 Continues until specified number reached"
          ]
        },
        "note": "User can cancel a selection list, redefine the FMI range and ask system to bring up a new list."
      }
    },
    "report_configuration": {
      "section": "3",
      "description": "User defines report specifics. System extracts four data inputs: FMI, PMI, VMI, RVS.",
      "data_inputs": [
        {
          "code": "FMI",
          "description": "System retrieves all FMI scores for all criterions included"
        },
        {
          "code": "PMI",
          "description": "System retrieves all PMI scores for all assessments for all criterions included"
        },
        {
          "code": "VMI",
          "description": "System retrieves all VMI scores for all Variables of assessments for all criterions included"
        },
        {
          "code": "RVS",
          "description": "System retrieves all Raw Summary scores for all variables of all assessments included"
        }
      ],
      "note": "Band definition and table/graph layout processes are common for all data inputs but values included differ. User should define each data type separately.",
