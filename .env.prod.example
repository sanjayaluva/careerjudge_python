# Production environment — OCI Ampere A1 (1 OCPU / 6 GB)
# All services on one VM. DB: local Postgres. Redis: local.

# === IMPORTANT ===
# Copy to .env.prod and fill in REAL values.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# NEVER commit .env.prod to git.

# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=__GENERATE_A_NEW_SECRET_KEY__
DEBUG=false
ALLOWED_HOSTS=careerjudge.pp.ua,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://careerjudge.pp.ua

# Postgres (local container)
POSTGRES_DB=careerjudge
POSTGRES_USER=cj
POSTGRES_PASSWORD=__SET_A_STRONG_PASSWORD__
DATABASE_URL=postgres://cj:__SET_A_STRONG_PASSWORD__@db:5432/careerjudge

# Redis (local container)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# JWT
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Email (SMTP — configure with your provider)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=__SMTP_API_KEY__
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@careerjudge.pp.ua

# Frontend URL
FRONTEND_URL=https://careerjudge.pp.ua

# Sentry (optional)
SENTRY_DSN=

# Frontend
VITE_API_BASE_URL=/api
VITE_APP_NAME=CareerJudge

# S3-compatible object storage (OCI Object Storage or Cloudflare R2)
USE_S3_STORAGE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
