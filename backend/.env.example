# Backend .env example — copy to `.env` and fill in.
# Root .env.example has the full list; this is backend-only subset.

DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=dev-secret-key-change-in-prod
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

DATABASE_URL=postgres://postgres:postgres@localhost:5432/careerjudge

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=true

JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@careerjudge.pp.ua
FRONTEND_URL=http://localhost:5173
