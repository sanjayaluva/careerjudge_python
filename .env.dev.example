# Dev environment — GCP CE (1 vCPU / 1 GB)
# DB: external Neon free tier. Redis skipped (Celery runs eager).

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=CHANGE-ME-50-char-random-string-for-dev
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,35.207.59.232,careerjudge.pp.ua
CORS_ALLOWED_ORIGINS=https://careerjudge.pp.ua,http://localhost:5173

# Neon Postgres (external, free tier)
DATABASE_URL=postgresql://neondb_owner:npg_ZnFCg4ku8Xtj@ep-lingering-math-atahj4ng-pooler.c-9.us-east-1.aws.neon.tech/careerjudge?sslmode=require

# Redis (skipped in dev — Celery eager mode)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=true

# JWT
# Access token: 60 min (long enough for active question editing without
# mid-session refresh; the frontend axios interceptor auto-refreshes on 401).
# Refresh token: 30 days (so users stay logged in across browser restarts).
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# Email (console in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@careerjudge.pp.ua

# Frontend URL (for email links)
FRONTEND_URL=https://careerjudge.pp.ua

# Frontend
VITE_API_BASE_URL=/api
VITE_APP_NAME=CareerJudge
