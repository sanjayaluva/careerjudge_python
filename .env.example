# =============================================================================
# CareerJudge — Root environment example
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Backend ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,35.208.224.41,careerjudge.pp.ua
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://careerjudge.pp.ua

# Database (dev: Neon free tier; prod: Postgres on OCI VM)
DATABASE_URL=postgres://user:password@host:5432/careerjudge

# Redis (skip in dev — Celery runs eager)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
# Access token: 60 min (long enough for active question editing without
# mid-session refresh; the frontend axios interceptor auto-refreshes on 401).
# Refresh token: 30 days (so users stay logged in across browser restarts).
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# Email (dev: console backend; prod: SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@careerjudge.pp.ua

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Sentry (optional)
SENTRY_DSN=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api
VITE_APP_NAME=CareerJudge

# --- CI/CD deploy (fill in GitHub Actions secrets, not here) ---
# DEV_SSH_HOST=35.208.224.41
# DEV_SSH_USER=deploy
# PROD_SSH_HOST=
# PROD_SSH_USER=deploy
